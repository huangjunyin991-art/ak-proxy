# AK-Proxy 环境变量参考模板（不含秘密值，仅供对照）
# 存放路径：/etc/ak-proxy/ak-proxy.env
#
# 变量说明：
#   #AUTO#  首次运行脚本时由 ensure_env.py 自动生成
#   #必填#  必须人工填写，缺失会导致服务无法启动
#   #可选#  有默认值，缺失时使用默认值（通常无需填写）
#
# 已有值请勿删除或修改，脚本不会覆盖已有项

# ============================================================
# 核心密钥（#必填#）
# ============================================================
# 管理员面板登录密码（#必填#）
#ADMIN_PASSWORD=

# PostgreSQL 数据库密码（#必填#）
#AK_PROXY_DB_PASSWORD=

# 数据库二级密码（可选，#必填# 如开启二级验证）
#DB_SECONDARY_PASSWORD=

# IM AI 凭据加密主密钥（#AUTO# - 自动生成，生成后不要修改）
# 用于加密保存 Provider sk、中转站控制台密码和 session；修改会导致已保存凭据无法解密。
#IM_AI_SECRET_KEY=（自动生成，勿手动填写）

# ============================================================
# IM 服务（#必填#）
# ============================================================
# IM PostgreSQL 数据库连接串（#必填#）
#IM_DATABASE_URL=

# 允许访问 IM API 的公网 Origin（#必填#）
#IM_ALLOWED_ORIGIN=https://ak2025.vip

# ============================================================
# 通知中心（#AUTO# - 脚本首次运行自动生成）
# ============================================================
# 通知中心总开关（默认 1，即启用）
#NOTIFY_CENTER_ENABLED=1

# 通知中心内部密钥（自动生成，用于 webhook 签名验证）
#NOTIFY_CENTER_INTERNAL_SECRET=（自动生成，勿手动填写）

# Web Push VAPID 公钥（自动生成）
#WEB_PUSH_VAPID_PUBLIC_KEY=（自动生成，勿手动填写）

# Web Push VAPID 私钥（自动生成）
#WEB_PUSH_VAPID_PRIVATE_KEY=（自动生成，勿手动填写）

# VAPID 发送方标识（默认 mailto:admin@ak2025.vip）
#WEB_PUSH_VAPID_SUBJECT=mailto:admin@ak2025.vip

# ============================================================
# 可选配置（#可选# - 有默认值，缺失时自动使用默认值）
# ============================================================
# 公网可访问的基础 URL（用于回调等场景）
#NOTIFY_CENTER_PUBLIC_BASE_URL=

# ntfy 通知服务器（默认 https://ntfy.ak2025.vip）
#NOTIFY_CENTER_NTFY_DEFAULT_SERVER_URL=https://ntfy.ak2025.vip

# Worker 轮询间隔秒数（默认 5，最小 2）
#NOTIFY_CENTER_WORKER_INTERVAL_SECONDS=5

# 是否在通知中显示消息预览（默认 0，即不显示）
#NOTIFY_CENTER_SHOW_MESSAGE_PREVIEW=0

# 激活码代理服务器地址（可选）
#LICENSE_SERVER_URL=https://your-license-server.com
#LICENSE_ADMIN_KEY=

# FastAPI 跨域白名单，逗号分隔；同源管理面板通常无需配置
#AK_CORS_ALLOWED_ORIGINS=https://ak2025.vip

# ============================================================
# 不在此文件中的变量（由 systemd service 直接注入或其他途径）
# ============================================================
# IM_SERVER_INTERNAL_URL           - IM 服务内部 URL，默认 http://127.0.0.1:18081
# IM_LOCATION_AMAP_WEB_KEY        - 高德地图 Web API Key
# IM_LOCATION_AMAP_SECURITY_JS_CODE - 高德地图安全密钥
# MONITOR_SERVER / MONITOR_API_KEY - 监控服务配置
